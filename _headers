# Cloudflare Pages _headers
# 보안 헤더 설정 (모든 경로에 적용)
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  # ✅ 보안: connect-src에서 crm.thecalibration.kr 제거
  #          브라우저는 /api/auction-data(동일 출처)만 호출하므로 외부 도메인 불필요
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://dapi.kakao.com http://dapi.kakao.com https://*.daumcdn.net http://*.daumcdn.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' data: https://fonts.gstatic.com https://cdn.jsdelivr.net; connect-src 'self' https://dapi.kakao.com http://dapi.kakao.com; img-src 'self' data: https://*.daumcdn.net http://*.daumcdn.net;
